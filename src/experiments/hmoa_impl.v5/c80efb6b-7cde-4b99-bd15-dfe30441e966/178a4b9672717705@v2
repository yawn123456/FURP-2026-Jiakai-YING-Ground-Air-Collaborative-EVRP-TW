#!/usr/bin/env python
"""Parallel HMOA experiment on Dumas w80 instances — paper parameters."""
import sys, os, time, json, numpy as np
from datetime import datetime
from multiprocessing import Pool, cpu_count, Manager
from functools import partial

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
os.chdir(os.path.dirname(os.path.abspath(__file__)))

import config
config.POPULATION_SIZE = 100
config.MAX_ITERATIONS = 500
config.MAX_PF_SIZE = 10000
config.KMAX = 5
config.CROSSOVER_RATE = 0.8
config.MUTATION_RATE = 0.3

from utils import load_dumas_instance
from algorithm import hmoa
from metrics import compute_hypervolume, compute_c_metric, get_reference_point

INSTANCES = [
    ('n20w80_001', 'dumas_instances/n20w80.001.txt'),
    ('n20w80_002', 'dumas_instances/n20w80.002.txt'),
    ('n20w80_003', 'dumas_instances/n20w80.003.txt'),
    ('n20w80_004', 'dumas_instances/n20w80.004.txt'),
    ('n20w80_005', 'dumas_instances/n20w80.005.txt'),
    ('n40w80_001', 'dumas_instances/n40w80.001.txt'),
    ('n40w80_002', 'dumas_instances/n40w80.002.txt'),
    ('n40w80_003', 'dumas_instances/n40w80.003.txt'),
    ('n40w80_004', 'dumas_instances/n40w80.004.txt'),
    ('n40w80_005', 'dumas_instances/n40w80.005.txt'),
    ('n60w80_001', 'dumas_instances/n60w80.001.txt'),
    ('n60w80_002', 'dumas_instances/n60w80.002.txt'),
    ('n60w80_003', 'dumas_instances/n60w80.003.txt'),
    ('n60w80_004', 'dumas_instances/n60w80.004.txt'),
    ('n60w80_005', 'dumas_instances/n60w80.005.txt'),
    ('n80w80_001', 'dumas_instances/n80w80.001.txt'),
    ('n80w80_002', 'dumas_instances/n80w80.002.txt'),
    ('n80w80_003', 'dumas_instances/n80w80.003.txt'),
    ('n80w80_004', 'dumas_instances/n80w80.004.txt'),
    ('n80w80_005', 'dumas_instances/n80w80.005.txt'),
]

NRUNS = 15
OUTDIR = 'output/parallel_w80'
os.makedirs(OUTDIR, exist_ok=True)
os.makedirs(f'{OUTDIR}/pfs', exist_ok=True)

def run_one(instance_name, run_idx, seed_offset=0):
    """Run HMOA once on a given instance. Returns (pf, time, instance_name, run_idx)."""
    seed = hash(f'{instance_name}_{run_idx}') % (2**31) + seed_offset
    t0 = time.time()
    pf, _, _ = hmoa(load_dumas_instance(INSTANCES_DICT[instance_name], num_drones=2),
                    100, 500, seed, verbose=False)
    elapsed = time.time() - t0
    return pf, elapsed, instance_name, run_idx

def run_batch(args):
    """Run a batch of runs for one instance. Returns results dict."""
    name, fpath, start_run, nruns = args
    inst = load_dumas_instance(fpath, num_drones=2)
    pfs, times = [], []
    for r in range(start_run, start_run + nruns):
        seed = hash(f'{name}_{r}') % (2**31)
        t0 = time.time()
        pf, _, _ = hmoa(inst, 100, 500, seed, verbose=False)
        elapsed = time.time() - t0
        pfs.append(pf)
        times.append(elapsed)
        c_vals = [s._cost for s in pf if s._cost]
        s_vals = [s._satisfaction for s in pf if s._satisfaction]
        if c_vals:
            print(f'  [{datetime.now():%H:%M:%S}] {name} run{r+1:2d}: PF={len(pf)}, cost=[{min(c_vals):.0f},{max(c_vals):.0f}], sat=[{min(s_vals):.1f},{max(s_vals):.1f}], {elapsed:.0f}s')
    return name, pfs, times

# Build instance dict
INSTANCES_DICT = dict(INSTANCES)
NAMES = [n for n, _ in INSTANCES]

# Build work batches: one per instance, all runs
batches = [(name, fpath, 0, NRUNS) for name, fpath in INSTANCES]

n_workers = min(cpu_count(), len(INSTANCES))
print('=' * 70)
print(f'  HMOA PARALLEL EXPERIMENT — Paper Parameters')
print(f'  Instances: {len(INSTANCES)} (n=20,40,60,80 × 5)')
print(f'  Runs/instance: {NRUNS} | Total runs: {len(INSTANCES) * NRUNS}')
print(f'  Workers: {n_workers}')
print(f'  Params: pop=100, iter=500, kmax=5, pc=0.8, pm=0.3')
print(f'  Started: {datetime.now():%Y-%m-%d %H:%M:%S}')
print('=' * 70)

t_start = time.time()
all_results = {}

with Pool(processes=n_workers) as pool:
    for name, pfs, times in pool.imap_unordered(run_batch, batches):
        # Save PF data
        pf_costs = [[float(s._cost) for s in pf if s._cost] for pf in pfs]
        pf_sats = [[float(s._satisfaction) for s in pf if s._satisfaction] for pf in pfs]

        # Compute reference point from all runs of this instance
        all_pf_sols = []
        for pf in pfs:
            all_pf_sols.extend(pf)
        ref = get_reference_point([all_pf_sols]) if all_pf_sols else (1, -1)

        # HV per run
        hvs = [compute_hypervolume(pf, ref) for pf in pfs if pf]

        all_results[name] = {
            'n': int(name.split('w')[0][1:]),
            'pf_sizes': [len(pf) for pf in pfs],
            'hv_mean': float(np.mean(hvs)), 'hv_std': float(np.std(hvs)),
            'time_mean': float(np.mean(times)), 'time_std': float(np.std(times)),
            'time_total': float(np.sum(times)),
            'ref_point': (float(ref[0]), float(ref[1])),
            'cost_min': float(min(min(c) for c in pf_costs if c)),
            'cost_max': float(max(max(c) for c in pf_costs if c)),
            'sat_min': float(min(min(s) for s in pf_sats if s)),
            'sat_max': float(max(max(s) for s in pf_sats if s)),
        }

        # Save best PF
        if hvs:
            best_pf = pfs[np.argmax(hvs)]
            pf_data = [{'cost': float(s._cost), 'sat': float(s._satisfaction),
                        'truck': s.truck_route,
                        'drones': [(d.drone_id,d.launch_node,d.customer,d.retrieve_node)
                                   for d in s.drone_deliveries]}
                       for s in best_pf if s._cost is not None]
            with open(f'{OUTDIR}/pfs/{name}_best.json', 'w') as f:
                json.dump(pf_data, f, indent=2)

        # Save incremental results
        with open(f'{OUTDIR}/results.json', 'w') as f:
            json.dump(all_results, f, indent=2, default=str)

        elapsed = time.time() - t_start
        n_done = len(all_results)
        print(f'  [{datetime.now():%H:%M:%S}] COMPLETED: {name} ({n_done}/{len(INSTANCES)}), '
              f'total elapsed: {elapsed:.0f}s')

# Final summary
t_total = time.time() - t_start
print(f'\n{"="*80}')
print(f'  FINAL RESULTS — Paper Parameters (w=80, pop=100, iter=500, kmax=5)')
print(f'  Total time: {t_total:.0f}s ({t_total/3600:.1f}h)')
print(f'{"="*80}')
print(f'{"Instance":<16} {"n":<5} {"Time/run":<10} {"Total":<10} {"HV":<20} {"Cost range":<20} {"Sat range":<20}')
print('-'*80)
for name, r in sorted(all_results.items()):
    print(f'{name:<16} {r["n"]:<5} {r["time_mean"]:<10.0f}s {r["time_total"]:<10.0f}s '
          f'{r["hv_mean"]:.2f}+/-{r["hv_std"]:.1f}   '
          f'[{r["cost_min"]:.0f},{r["cost_max"]:.0f}]          '
          f'[{r["sat_min"]:.1f},{r["sat_max"]:.1f}]')

# Summary by size
print(f'\n--- By Size ---')
for n_size in [20, 40, 60, 80]:
    sub = {k: v for k, v in all_results.items() if v['n'] == n_size}
    if sub:
        avg_t = np.mean([v['time_mean'] for v in sub.values()])
        avg_hv = np.mean([v['hv_mean'] for v in sub.values()])
        avg_pf = np.mean([np.mean(v['pf_sizes']) for v in sub.values()])
        print(f'  n={n_size}: avg_time={avg_t:.0f}s/run, avg_HV={avg_hv:.2f}, avg_PF={avg_pf:.0f}')

print(f'\nResults saved to {OUTDIR}/results.json')
print(f'Completed: {datetime.now():%Y-%m-%d %H:%M:%S}')
