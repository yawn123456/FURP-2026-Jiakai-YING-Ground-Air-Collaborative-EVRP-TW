PLS_OPERATORS = {
    'N4': operator_n4_2opt,
    'N5': operator_n5_greedy_deletion_reinsertion,
    'N6': operator_n6_random_deletion_reinsertion,
}

# All operators for general use
ALL_OPERATORS = {
    'N1': operator_n1_truck_to_drone,
    'N2': operator_n2_drone_to_truck,
    'N3': operator_n3_swap,
    'N4': operator_n4_2opt,
    'N5': operator_n5_greedy_deletion_reinsertion,
    'N6': operator_n6_random_deletion_reinsertion,
}


def apply_operator(name: str, instance: ProblemInstance, solution: Solution,
                   random_state: np.random.RandomState) -> Solution:
    """Apply a named operator to a solution."""
    if name in ALL_OPERATORS:
        return ALL_OPERATORS[name](instance, solution, random_state)
    raise ValueError(f"Unknown operator: {name}")
