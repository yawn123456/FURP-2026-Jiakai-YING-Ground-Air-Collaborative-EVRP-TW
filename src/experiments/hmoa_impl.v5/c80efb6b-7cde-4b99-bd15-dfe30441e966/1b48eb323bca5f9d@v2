sys.path.insert(0, ROOT)
sys.path.insert(0, os.path.join(ROOT, 'core'))
os.chdir(ROOT)

import config
config.POPULATION_SIZE = 200
config.MAX_ITERATIONS = 200
config.KMAX = 5
config.MAX_PF_SIZE = 500

WORKER_SCRIPT = os.path.join(ROOT, 'core', 'worker.py')

INSTANCES = [
    ('n20w80_001', 'dumas_instances/n20w80.001.txt'),
    ('n20w80_002', 'dumas_instances/n20w80.002.txt'),
    ('n20w80_003', 'dumas_instances/n20w80.003.txt'),
    ('n20w80_004', 'dumas_instances/n20w80.004.txt'),
    ('n20w80_005', 'dumas_instances/n20w80.005.txt'),
    ('n40w80_001', 'dumas_instances/n40w80.001.txt'),
    ('n40w80_002', 'dumas_instances/n40w80.002.txt'),
    ('n40w80_003', 'dumas_instances/n40w80.003.txt'),
    ('n40w80_004', 'dumas_instances/n40w80.004.txt'),
    ('n40w80_005', 'dumas_instances/n40w80.005.txt'),
    ('n60w80_001', 'dumas_instances/n60w80.001.txt'),
    ('n60w80_002', 'dumas_instances/n60w80.002.txt'),
    ('n60w80_003', 'dumas_instances/n60w80.003.txt'),
    ('n60w80_004', 'dumas_instances/n60w80.004.txt'),
    ('n60w80_005', 'dumas_instances/n60w80.005.txt'),
    ('n80w80_001', 'dumas_instances/n80w80.001.txt'),
    ('n80w80_002', 'dumas_instances/n80w80.002.txt'),
    ('n80w80_003', 'dumas_instances/n80w80.003.txt'),
    ('n80w80_004', 'dumas_instances/n80w80.004.txt'),
    ('n80w80_005', 'dumas_instances/n80w80.005.txt'),
]

# 两个实验共用输出目录
OUTDIR_HMOA = 'output/experiment_gnn_hmoa'
OUTDIR_GNN = 'output/experiment_gnn_gnn'
MAX_WORKERS = 10


def run_experiment(instances, outdir, label, env_extra=None):
    """运行一组实验，使用 worker.py 子进程。"""
    os.makedirs(outdir, exist_ok=True)
    os.makedirs(f'{outdir}/pfs', exist_ok=True)

    todo = []
    for name, fpath in instances:
        if os.path.exists(f'{outdir}/{name}.json'):
            print(f'  SKIP {name} (already done in {label})')
        else:
            todo.append((name, fpath))

    if not todo:
        print(f'  {label}: All instances already completed!')
        return

    n_total = len(todo)
    print(f'\n{"=" * 60}')
    print(f'  {label} — {n_total} instances')
    print(f'  pop={config.POPULATION_SIZE}, iter={config.MAX_ITERATIONS}')
    print(f'  Workers: {MAX_WORKERS}')
    print(f'  Started: {datetime.now():%Y-%m-%d %H:%M:%S}')
    print(f'{"=" * 60}')

    base_env = {**os.environ, 'PYTHONUTF8': '1',
                'OPENBLAS_NUM_THREADS': '1', 'OMP_NUM_THREADS': '1'}
    if env_extra:
        base_env.update(env_extra)

    active = {}
    pending = list(todo)
    t_start = time.time()
    done, fail = 0, 0

    # Launch initial batch
    for name, fpath in pending[:MAX_WORKERS]:
        abs_path = os.path.abspath(fpath)
        cmd = [sys.executable, '-u', WORKER_SCRIPT, name, abs_path,
               str(config.MAX_ITERATIONS), outdir]
        proc = subprocess.Popen(cmd, stdout=subprocess.PIPE,
                                stderr=subprocess.STDOUT, text=True, env=base_env)
        active[proc] = (name, fpath)
    pending = pending[MAX_WORKERS:]

    while active:
        for proc in list(active.keys()):
            name, fpath = active[proc]
            for line in iter(proc.stdout.readline, ''):
                if not line:
                    break
                line = line.rstrip()
                if line:
                    print(f'  [{label}/{name}] {line}', flush=True)
            ret = proc.poll()
            if ret is not None:
                success = ret == 0
                if success:
                    done += 1
                else:
                    fail += 1
                elapsed = time.time() - t_start
                status = 'DONE' if success else 'FAIL'
                print(f'  [{datetime.now():%H:%M:%S}] {status} {label}/{name} '
                      f'({done}/{n_total}), elapsed={elapsed:.0f}s')
                del active[proc]
                if pending:
                    nxt_name, nxt_path = pending.pop(0)
                    abs_path = os.path.abspath(nxt_path)
                    cmd = [sys.executable, '-u', WORKER_SCRIPT, nxt_name,
                           abs_path, str(config.MAX_ITERATIONS), outdir]
                    new_proc = subprocess.Popen(cmd, stdout=subprocess.PIPE,
                                                stderr=subprocess.STDOUT,
                                                text=True, env=base_env)
                    active[new_proc] = (nxt_name, nxt_path)
                break
        else:
            time.sleep(0.5)

    t_total = time.time() - t_start
    print(f'\n  {label} 完成: 成功={done}, 失败={fail}, 耗时={t_total:.0f}s')
    return done, fail, t_total


def compare_results():
    """对比两组实验结果并打印汇总表。"""
    import numpy as np

    results_h, results_g = {}, {}

    for name, _ in INSTANCES:
        for rdict, outdir in [(results_h, OUTDIR_HMOA), (results_g, OUTDIR_GNN)]:
            path = f'{outdir}/{name}.json'
            if os.path.exists(path):
                rdict[name] = json.load(open(path))

    print(f'\n{"=" * 100}')
    print(f'  GNN-HMOA vs 原始 HMOA — 对比结果')
    print(f'  iter={config.MAX_ITERATIONS}, pop={config.POPULATION_SIZE}')
    print(f'{"=" * 100}')
    print(f'{"Instance":<14} {"C(H,GNN)":<12} {"C(GNN,H)":<12} {"HV(H)":<10} '
          f'{"HV(GNN)":<10} {"Winner":<8} {"T(H)":<7} {"T(GNN)":<7}')
    print(f'{"-" * 80}')

    c_hgnn_all, c_gnnh_all = [], []
    hv_h_all, hv_g_all = [], []

    for name in sorted(results_h.keys()):
        r_h = results_h.get(name)
        r_g = results_g.get(name)
        if not r_h or not r_g:
            continue

        c_hg = r_h.get('c_hn_mean', 0)
        c_gh = r_h.get('c_nh_mean', 0)
        hv_h = r_h.get('hv_hmoa_mean', 0)
        hv_g = r_g.get('hv_hmoa_mean', 0)
        t_h = r_h.get('time_hmoa_mean', 0)
        t_g = r_g.get('time_hmoa_mean', 0)

        # C-metric between the two: compare HMOA vs GNN-HMOA PFs
        # For now, use HV ratio as indicator
        winner = 'HMOA' if hv_h > hv_g else ('GNN' if hv_g > hv_h else 'TIE')

        c_hgnn_all.append(c_hg)
        c_gnnh_all.append(c_gh)
        hv_h_all.append(hv_h)
        hv_g_all.append(hv_g)

        print(f'{name:<14} {c_hg:<12.4f} {c_gh:<12.4f} {hv_h:<10.1f} '
              f'{hv_g:<10.1f} {winner:<8} {t_h:<7.0f} {t_g:<7.0f}')

    # Summary by size
    print(f'\n--- 按规模汇总 ---')
    for n_size in [20, 40, 60, 80]:
        sub_h = {k: v for k, v in results_h.items()
                 if v.get('n', 0) == n_size}
        sub_g = {k: v for k, v in results_g.items()
                 if v.get('n', 0) == n_size}
        if not sub_h or not sub_g:
            continue
        hv_h = np.mean([v['hv_hmoa_mean'] for v in sub_h.values()])
        hv_g = np.mean([v['hv_hmoa_mean'] for v in sub_g.values()])
        t_h = np.mean([v['time_hmoa_mean'] for v in sub_h.values()])
        t_g = np.mean([v['time_hmoa_mean'] for v in sub_g.values()])
        print(f'  n={n_size}: HV(H)={hv_h:.1f}, HV(GNN)={hv_g:.1f}, '
              f'T(H)={t_h:.0f}s, T(GNN)={t_g:.0f}s')

    # Overall
    if hv_h_all:
        print(f'\n  全局平均: HV(H)={np.mean(hv_h_all):.1f}, '
              f'HV(GNN)={np.mean(hv_g_all):.1f}')


